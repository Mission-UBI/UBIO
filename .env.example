# ---- Network ----
# "testnet" (default, safe) or "mainnet" (real funds).
BTC_NETWORK=testnet
# Required ONLY when BTC_NETWORK=mainnet — an explicit acknowledgement that the
# wallet key lives in plaintext next to a public web surface. Leave unset for testnet.
# I_UNDERSTAND_MAINNET_RISK=yes

# ---- Server ----
PORT=3000

# ---- Database ----
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=ubio

# ---- Wallet ----
# Public receive address (native segwit / P2WPKH recommended).
WALLET_ADDRESS=
# The wallet's PRIVATE KEY in WIF format.
WALLET_PRIVATE_KEY=

# ---- Admin ----
# Admin panel password; also accepted as the API bearer token.
ADMIN_PASSWORD=
# Optional: a random secret for signing session cookies (defaults to ADMIN_PASSWORD).
SESSION_SECRET=

# ---- Display ----
INSTITUTION_NAME=Example Mutual Aid

# ---- Cadence (neither was in the original spec's env list) ----
# How often the whole pool is distributed, in milliseconds. Default: 7 days.
DISTRIBUTION_INTERVAL_MS=604800000
# How often the scheduler checks the clock, in milliseconds. Default: 60s.
SCHEDULER_TICK_MS=60000

# ---- Bitcoin backend ----
# Esplora-compatible REST API. Defaults to Blockstream for the chosen network.
# ESPLORA_BASE_URL=https://blockstream.info/testnet/api
